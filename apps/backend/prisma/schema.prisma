generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STUDENT
  COLLEGE
  COMPANY
}

enum ProjectCategory {
  WEB_DEVELOPMENT
  MOBILE_APP
  MACHINE_LEARNING
  DATA_SCIENCE
  BLOCKCHAIN
  IOT
  CLOUD_COMPUTING
  CYBERSECURITY
  GAME_DEVELOPMENT
  DEVOPS
  OTHER
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchases Purchase[]
  reviews   Review[]
  requests  Request[]
  messages  Message[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Project {
  id              String          @id @default(uuid())
  title           String
  description     String
  longDescription String?         @map("long_description")
  price           Decimal         @db.Decimal(10, 2)
  category        ProjectCategory
  techStack       String[]        @map("tech_stack")
  features        String[]        @default([])
  fileUrl         String          @map("file_url")
  fileKey         String          @map("file_key")
  thumbnailUrl    String?         @map("thumbnail_url")
  isFeatured      Boolean         @default(false) @map("is_featured")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  purchases Purchase[]
  reviews   Review[]

  @@index([category])
  @@index([isActive, isFeatured])
  @@index([price])
  @@index([createdAt])
  @@map("projects")
}

model Purchase {
  id              String         @id @default(uuid())
  userId          String         @map("user_id")
  projectId       String         @map("project_id")
  amount          Decimal        @db.Decimal(10, 2)
  razorpayOrderId String?        @unique @map("razorpay_order_id")
  razorpayPaymentId String?      @unique @map("razorpay_payment_id")
  razorpaySignature String?      @map("razorpay_signature")
  status          PurchaseStatus @default(PENDING)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([razorpayOrderId])
  @@map("purchases")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([rating])
  @@map("reviews")
}

model Request {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  requirementDetails String        @map("requirement_details")
  budget             Decimal?      @db.Decimal(10, 2)
  deadline           DateTime?
  status             RequestStatus @default(PENDING)
  adminNotes         String?       @map("admin_notes")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("requests")
}

model Message {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  subject   String
  content   String
  isRead    Boolean  @default(false) @map("is_read")
  reply     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("messages")
}
