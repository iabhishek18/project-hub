# Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/project_hub

# JWT Secrets (generate strong random strings)
JWT_SECRET=your-jwt-secret-min-32-chars-long-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-change-this

# Admin Credentials (single admin user)
ADMIN_EMAIL=admin@projecthub.com
ADMIN_PASSWORD=AdminSecurePassword123!

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=project-hub-files
